# Database
DB_URL=jdbc:postgresql://localhost:5432/his_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JPA / logging
# Use update only for local development. Use validate with Flyway-managed schemas.
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=false
APP_LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=WARN

# JWT and account tokens
JWT_SECRET=replace-with-a-256-bit-base64-secret
JWT_EXPIRATION=86400000
REFRESH_TOKEN_EXPIRATION=604800000
REFRESH_TOKEN_CLEANUP_ENABLED=true
REFRESH_TOKEN_CLEANUP_INITIAL_DELAY=600000
REFRESH_TOKEN_CLEANUP_FIXED_DELAY=3600000
EMAIL_VERIFICATION_EXPIRATION=86400000
PASSWORD_RESET_EXPIRATION=900000

# Application URL
APP_BASE_URL=http://localhost:8080

# CORS
# Development: http://localhost:4200
# Production: https://your-frontend-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Swagger / OpenAPI
# Development: true
# Production: false unless protected behind internal/admin access
SWAGGER_ENABLED=true

# Mail
MAIL_PROVIDER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_PASSWORD=your-google-app-password
